{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cd web && npm *)",
      "Bash(cd web && npx *)",
      "Bash(cd /workspaces/ttv-website/web && npm *)",
      "Bash(cd /workspaces/ttv-website/web && npx *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Read(web/src/**)",
      "Read(web/scripts/**)",
      "Read(web/docs/**)",
      "Edit(web/src/**)",
      "Edit(web/package.json)",
      "Write(web/src/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(*> /dev/sd*)",
      "Bash(mkfs*)",
      "Bash(dd if=*)"
    ]
  }
}
