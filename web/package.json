{
  "name": "ttv-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma migrate dev && next dev",
    "build": "next build && npm run migrate:deploy",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "migrate-dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy || echo 'Database unavailable, skipping migrations'",
    "test": "jest",
    "dev:docker:up": "docker compose -f ../compose.yaml up -d",
    "dev:docker:down": "docker compose -f ../compose.yaml down",
    "test:docker": "docker compose -f ../compose.test.yaml run --rm test-runner",
    "test:docker:down": "docker compose -f ../compose.test.yaml down -v"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.556.0",
    "@aws-sdk/s3-request-presigner": "^3.556.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@gsap/react": "^2.1.0",
    "@hono/auth-js": "^1.0.7",
    "@hono/zod-validator": "^0.2.1",
    "@mui/icons-material": "^5.14.18",
    "@mui/material": "^5.14.18",
    "@mui/x-data-grid": "^7.5.1",
    "@mui/x-date-pickers": "^7.7.1",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@rudderstack/analytics-js": "^3.0.3",
    "@rudderstack/rudder-sdk-node": "^2.0.7",
    "@sanity/image-url": "^2.0.1",
    "@sanity/vision": "^4.19.0",
    "@types/node": "22.9.0",
    "@types/react": "18.2.22",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.16",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.11",
    "eslint": "9.14.0",
    "eslint-config-next": "16.0.6",
    "gsap": "^3.12.5",
    "hono": "^4.3.2",
    "jotai": "^2.8.0",
    "js-sha256": "^0.10.1",
    "next": "^16.0.6",
    "next-auth": "^4.24.7",
    "next-sanity": "^11.6.10",
    "nodemailer": "^7.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.0.1",
    "react-markdown": "^9.0.1",
    "sanity": "^4.19.0",
    "sharp": "^0.32.6",
    "styled-components": "^6.1.8",
    "swr": "^2.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "zod": "^3.23.6",
    "@uiw/react-md-editor": "^3.23.0",
    "@uiw/react-markdown-preview": "^5.1.5",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "3.3.3",
    "prisma": "^7.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
