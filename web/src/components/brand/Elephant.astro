---
/**
 * Elephant mark (PROPOSAL §C.3 / §4 / §6).
 *
 * Minimal single-stroke elephant silhouette. Used as the nav monogram
 * companion and the footer/auth signature. Takes a `breathing` prop
 * that applies a subtle scale loop (respecting prefers-reduced-motion).
 */
interface Props {
  class?: string;
  size?: number;
  strokeWidth?: number;
  breathing?: boolean;
}

const { class: className = "", size = 48, strokeWidth = 1.6, breathing = false } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 120 80"
  width={size}
  height={(size * 80) / 120}
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={[className, breathing && "elephant-breathing"]}
  aria-hidden="true"
>
  <!-- Back / body -->
  <path d="M18 48 Q22 22 52 20 Q82 18 94 28 Q104 36 98 52" />
  <!-- Head + ear -->
  <path d="M94 28 Q100 24 102 34 Q104 46 96 46" />
  <!-- Trunk -->
  <path d="M104 40 Q112 44 110 54 Q108 62 100 60" />
  <!-- Belly -->
  <path d="M26 48 Q22 66 34 68" />
  <path d="M88 52 Q90 66 78 68" />
  <!-- Legs -->
  <path d="M36 56 L34 72" />
  <path d="M52 58 L52 72" />
  <path d="M72 58 L72 72" />
  <path d="M84 56 L86 72" />
  <!-- Eye -->
  <circle cx="97" cy="34" r="1.2" fill="currentColor" stroke="none" />
</svg>

<style>
  .elephant-breathing {
    animation: elephant-breathe 5s ease-in-out infinite;
    transform-origin: 60px 48px;
  }
  @keyframes elephant-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.025); }
  }
  @media (prefers-reduced-motion: reduce) {
    .elephant-breathing { animation: none; }
  }
</style>
