---
/**
 * Humans — cohort placeholder.
 *
 * Students asked for a place to show what they're building and who they
 * are. Until they've written their own profiles, this section renders as
 * a set of four empty portrait slots with editorial "placeholder" styling
 * — dashed borders, cohort labels only, no invented names. When real
 * profiles land, the SLOTS array gets populated and the dashed borders
 * turn solid.
 */

interface Slot {
  label: string;
}

const SLOTS: Slot[] = [
  { label: "Cohort 04 · Kenya" },
  { label: "Cohort 04 · Kenya" },
  { label: "Cohort 03 · Nigeria" },
  { label: "Cohort 02 · Alumni" },
];
---

<section id="humans" class="relative px-4 py-28 sm:px-8 md:py-36">
  <div class="mx-auto max-w-7xl">
    <div class="mb-14 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <p class="font-body text-xs font-semibold uppercase tracking-[0.4em] text-primary">
        § 03 The cohort
      </p>
      <p class="max-w-md font-body text-base text-ink-secondary md:text-lg">
        Students asked for a place to show who they are and what they&apos;re
        building. We&apos;re putting it together with them — profiles land
        with Cohort 04.
      </p>
    </div>

    <ul class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-4">
      {SLOTS.map((slot) => (
        <li class="space-y-3">
          <div
            class="relative aspect-[4/5] overflow-hidden border border-dashed border-[color:var(--color-rule)]"
            style="background-color: var(--color-bg-raised);"
          >
            <div class="flex h-full w-full items-center justify-center">
              <span
                class="font-heading text-primary/40"
                style="font-size: clamp(3rem, 7vw, 6rem); letter-spacing: -0.04em;"
              >
                —
              </span>
            </div>
          </div>
          <p class="font-body text-xs font-semibold uppercase tracking-[0.24em] text-ink-muted">
            Profile coming
          </p>
          <p class="font-body text-sm text-ink-muted">{slot.label}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
