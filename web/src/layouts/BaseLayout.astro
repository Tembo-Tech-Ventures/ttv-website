---
import "@/styles/global.css";

interface Props {
  title?: string;
}

const { title = "Tembo Tech Ventures" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tembo Tech Ventures - Tech Training Platform" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-dark min-h-screen">
    <slot />
  </body>
</html>
