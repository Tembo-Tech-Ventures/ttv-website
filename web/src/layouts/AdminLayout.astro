---
import BaseLayout from "./BaseLayout.astro";
import AdminShell from "@/components/shells/AdminShell";

interface Props {
  title?: string;
}

const { title = "Admin" } = Astro.props;

// Defense-in-depth: redirect if middleware didn't set isAdmin
if (!Astro.locals.isAdmin) {
  return Astro.redirect(Astro.locals.user ? "/dashboard" : "/auth/login");
}
---

<BaseLayout title={`${title} | TTV Admin`}>
  <AdminShell client:load>
    <slot />
  </AdminShell>
</BaseLayout>
