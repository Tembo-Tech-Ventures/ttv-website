---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { drizzle } from "drizzle-orm/d1";
import * as schema from "@/lib/db/schema";
import { env } from "cloudflare:workers";

const db = drizzle(env.DB, { schema });

const programs = await db.query.program.findMany({
  with: { curriculum: true },
  orderBy: (p, { desc }) => [desc(p.createdAt)],
});
---

<AdminLayout title="Programs">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-bold text-white">Programs</h2>
      <a
        href="/admin/programs/new"
        class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-dark hover:bg-primary/90"
      >
        New Program
      </a>
    </div>

    <div class="overflow-x-auto rounded-lg border border-teal/20">
      <table class="w-full text-left text-sm">
        <thead class="bg-teal/30 text-xs uppercase text-white/80">
          <tr>
            <th class="px-4 py-3 font-medium">Name</th>
            <th class="px-4 py-3 font-medium">Curriculum</th>
            <th class="px-4 py-3 font-medium">Start Date</th>
            <th class="px-4 py-3 font-medium">End Date</th>
            <th class="px-4 py-3 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-teal/10">
          {programs.length === 0 ? (
            <tr>
              <td colspan="5" class="px-4 py-8 text-center text-white/40">
                No programs yet
              </td>
            </tr>
          ) : (
            programs.map((p) => (
              <tr class="text-white/80 hover:bg-teal/10">
                <td class="px-4 py-3 font-medium text-white">{p.name}</td>
                <td class="px-4 py-3">{p.curriculum?.title ?? "—"}</td>
                <td class="px-4 py-3">
                  {p.startDate
                    ? new Date(p.startDate).toLocaleDateString()
                    : "—"}
                </td>
                <td class="px-4 py-3">
                  {p.endDate
                    ? new Date(p.endDate).toLocaleDateString()
                    : "—"}
                </td>
                <td class="px-4 py-3">
                  <a
                    href={`/admin/programs/${p.id}`}
                    class="text-primary hover:underline"
                  >
                    View
                  </a>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
