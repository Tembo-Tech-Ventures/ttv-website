---
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Data Migration">
  <div class="space-y-6">
    <h2 class="text-2xl font-bold text-white">Data Migration</h2>
    <p class="text-white/60">
      Import data from the Vercel/Prisma export into the Cloudflare D1 database.
    </p>

    <!-- Upload Section -->
    <div class="rounded-lg border border-teal/20 bg-dark/80 p-6 shadow-lg">
      <h3 class="mb-4 text-lg font-semibold text-white">Upload Export File</h3>
      <p class="mb-4 text-sm text-white/60">
        Select a JSON export file generated by the data export tool. The file
        must contain <code class="rounded bg-white/10 px-1">version</code> and
        <code class="rounded bg-white/10 px-1">exportedAt</code> fields.
      </p>

      <input
        id="file-input"
        type="file"
        accept=".json"
        class="block w-full cursor-pointer rounded-lg border border-teal/20 bg-dark/60 text-sm text-white/80 file:mr-4 file:cursor-pointer file:rounded-l-lg file:border-0 file:bg-primary/80 file:px-4 file:py-2.5 file:text-sm file:font-medium file:text-white hover:file:bg-primary"
      />

      <div id="file-error" class="mt-3 hidden rounded-lg border border-red-500/30 bg-red-500/10 p-3 text-sm text-red-300"></div>
    </div>

    <!-- Preview Section (hidden until file parsed) -->
    <div id="preview-section" class="hidden space-y-4">
      <div class="rounded-lg border border-teal/20 bg-dark/80 p-6 shadow-lg">
        <h3 class="mb-2 text-lg font-semibold text-white">Export Details</h3>
        <dl class="mb-4 grid grid-cols-2 gap-2 text-sm">
          <dt class="text-white/60">Version</dt>
          <dd id="meta-version" class="text-white"></dd>
          <dt class="text-white/60">Exported At</dt>
          <dd id="meta-exported-at" class="text-white"></dd>
        </dl>

        <h3 class="mb-3 text-lg font-semibold text-white">Record Counts</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-teal/20 text-white/60">
                <th class="pb-2 pr-4">Table</th>
                <th class="pb-2 text-right">Records</th>
              </tr>
            </thead>
            <tbody id="preview-tbody" class="text-white"></tbody>
            <tfoot>
              <tr class="border-t border-teal/20 font-semibold text-primary">
                <td class="pt-2 pr-4">Total</td>
                <td id="preview-total" class="pt-2 text-right"></td>
              </tr>
            </tfoot>
          </table>
        </div>

        <div class="mt-6 flex items-center gap-4">
          <button
            id="import-btn"
            type="button"
            class="rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white shadow-md transition-colors hover:bg-primary/80 disabled:cursor-not-allowed disabled:opacity-50"
          >
            Import Data
          </button>
          <button
            id="clear-btn"
            type="button"
            class="rounded-lg border border-teal/20 px-6 py-2.5 text-sm font-medium text-white/60 transition-colors hover:text-white"
          >
            Clear
          </button>
        </div>
      </div>
    </div>

    <!-- Status Section (hidden until import executed) -->
    <div id="status-section" class="hidden">
      <div id="status-card" class="rounded-lg border p-6 shadow-lg">
        <h3 id="status-title" class="mb-2 text-lg font-semibold"></h3>
        <p id="status-message" class="mb-4 text-sm"></p>
        <div id="status-details" class="hidden overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-teal/20 text-white/60">
                <th class="pb-2 pr-4">Table</th>
                <th class="pb-2 text-right">Imported</th>
              </tr>
            </thead>
            <tbody id="status-tbody" class="text-white"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    const TABLE_DEFS: Array<{ key: string; label: string }> = [
      { key: "users", label: "Users" },
      { key: "roles", label: "Roles" },
      { key: "curricula", label: "Curricula" },
      { key: "programs", label: "Programs" },
      { key: "programRoles", label: "Program Roles" },
      { key: "programPartners", label: "Program Partners" },
      { key: "programApplications", label: "Program Applications" },
      { key: "userRoles", label: "User Roles" },
    ];

    let parsedData: Record<string, unknown> | null = null;

    const fileInput = document.getElementById("file-input") as HTMLInputElement;
    const fileError = document.getElementById("file-error") as HTMLDivElement;
    const previewSection = document.getElementById("preview-section") as HTMLDivElement;
    const previewTbody = document.getElementById("preview-tbody") as HTMLTableSectionElement;
    const previewTotal = document.getElementById("preview-total") as HTMLTableCellElement;
    const metaVersion = document.getElementById("meta-version") as HTMLElement;
    const metaExportedAt = document.getElementById("meta-exported-at") as HTMLElement;
    const importBtn = document.getElementById("import-btn") as HTMLButtonElement;
    const clearBtn = document.getElementById("clear-btn") as HTMLButtonElement;
    const statusSection = document.getElementById("status-section") as HTMLDivElement;
    const statusCard = document.getElementById("status-card") as HTMLDivElement;
    const statusTitle = document.getElementById("status-title") as HTMLElement;
    const statusMessage = document.getElementById("status-message") as HTMLElement;
    const statusDetails = document.getElementById("status-details") as HTMLDivElement;
    const statusTbody = document.getElementById("status-tbody") as HTMLTableSectionElement;

    function showError(msg: string) {
      fileError.textContent = msg;
      fileError.classList.remove("hidden");
      previewSection.classList.add("hidden");
      parsedData = null;
    }

    function hideError() {
      fileError.classList.add("hidden");
    }

    function resetUI() {
      hideError();
      previewSection.classList.add("hidden");
      statusSection.classList.add("hidden");
      parsedData = null;
      fileInput.value = "";
    }

    fileInput.addEventListener("change", async () => {
      hideError();
      statusSection.classList.add("hidden");

      const file = fileInput.files?.[0];
      if (!file) return;

      try {
        const text = await file.text();
        const data = JSON.parse(text);

        if (!data.version || !data.exportedAt) {
          showError("Invalid export file: missing 'version' or 'exportedAt' fields.");
          return;
        }

        parsedData = data;

        // Populate metadata
        metaVersion.textContent = String(data.version);
        metaExportedAt.textContent = new Date(data.exportedAt).toLocaleString();

        // Populate preview table
        previewTbody.innerHTML = "";
        let total = 0;
        for (const { key, label } of TABLE_DEFS) {
          const count = Array.isArray(data[key]) ? data[key].length : 0;
          total += count;
          const tr = document.createElement("tr");
          tr.className = "border-b border-teal/10";
          tr.innerHTML = `
            <td class="py-1.5 pr-4">${label}</td>
            <td class="py-1.5 text-right tabular-nums">${count}</td>
          `;
          previewTbody.appendChild(tr);
        }
        previewTotal.textContent = String(total);

        previewSection.classList.remove("hidden");
      } catch {
        showError("Failed to parse file. Please upload a valid JSON file.");
      }
    });

    clearBtn.addEventListener("click", resetUI);

    importBtn.addEventListener("click", async () => {
      if (!parsedData) return;

      importBtn.disabled = true;
      importBtn.textContent = "Importing…";
      statusSection.classList.add("hidden");

      try {
        const res = await fetch("/api/admin/import", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(parsedData),
        });

        const result = await res.json();

        statusSection.classList.remove("hidden");

        if (res.ok && result.success) {
          statusCard.className =
            "rounded-lg border border-green-500/30 bg-green-500/10 p-6 shadow-lg";
          statusTitle.className = "mb-2 text-lg font-semibold text-green-300";
          statusTitle.textContent = "Import Successful";
          statusMessage.className = "mb-4 text-sm text-green-200/80";
          statusMessage.textContent = `Executed ${result.totalStatements} statements using INSERT OR IGNORE.`;

          // Show per-table counts
          statusTbody.innerHTML = "";
          for (const { key, label } of TABLE_DEFS) {
            const count = result.imported?.[key] ?? 0;
            if (count > 0) {
              const tr = document.createElement("tr");
              tr.className = "border-b border-teal/10";
              tr.innerHTML = `
                <td class="py-1.5 pr-4">${label}</td>
                <td class="py-1.5 text-right tabular-nums">${count}</td>
              `;
              statusTbody.appendChild(tr);
            }
          }
          statusDetails.classList.remove("hidden");
        } else {
          statusCard.className =
            "rounded-lg border border-red-500/30 bg-red-500/10 p-6 shadow-lg";
          statusTitle.className = "mb-2 text-lg font-semibold text-red-300";
          statusTitle.textContent = "Import Failed";
          statusMessage.className = "mb-4 text-sm text-red-200/80";
          statusMessage.textContent = result.error || "An unknown error occurred.";
          statusDetails.classList.add("hidden");
        }
      } catch (err) {
        statusSection.classList.remove("hidden");
        statusCard.className =
          "rounded-lg border border-red-500/30 bg-red-500/10 p-6 shadow-lg";
        statusTitle.className = "mb-2 text-lg font-semibold text-red-300";
        statusTitle.textContent = "Import Failed";
        statusMessage.className = "mb-4 text-sm text-red-200/80";
        statusMessage.textContent =
          err instanceof Error ? err.message : "Network error";
        statusDetails.classList.add("hidden");
      } finally {
        importBtn.disabled = false;
        importBtn.textContent = "Import Data";
      }
    });
  </script>
</AdminLayout>
