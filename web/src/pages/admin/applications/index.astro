---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Badge from "@/components/common/Badge.astro";
import { drizzle } from "drizzle-orm/d1";
import * as schema from "@/lib/db/schema";
import { eq } from "drizzle-orm";
import { env } from "cloudflare:workers";

const db = drizzle(env.DB, { schema });

const statusFilter = Astro.url.searchParams.get("status");

let applications;
if (statusFilter) {
  applications = await db.query.programApplication.findMany({
    where: eq(schema.programApplication.status, statusFilter as any),
    with: { user: true, program: true },
    orderBy: (a, { desc }) => [desc(a.createdAt)],
  });
} else {
  applications = await db.query.programApplication.findMany({
    with: { user: true, program: true },
    orderBy: (a, { desc }) => [desc(a.createdAt)],
  });
}

const statuses = ["PENDING", "APPROVED", "REJECTED", "AUDIT", "COMPLETED"];
---

<AdminLayout title="Applications">
  <div class="space-y-6">
    <h2 class="text-2xl font-bold text-white">Applications</h2>

    <div class="flex flex-wrap gap-2">
      <a
        href="/admin/applications"
        class:list={[
          "rounded-full px-3 py-1 text-sm font-medium transition-colors",
          !statusFilter
            ? "bg-primary text-dark"
            : "bg-teal/20 text-white/60 hover:text-white",
        ]}
      >
        All
      </a>
      {statuses.map((s) => (
        <a
          href={`/admin/applications?status=${s}`}
          class:list={[
            "rounded-full px-3 py-1 text-sm font-medium capitalize transition-colors",
            statusFilter === s
              ? "bg-primary text-dark"
              : "bg-teal/20 text-white/60 hover:text-white",
          ]}
        >
          {s.toLowerCase()}
        </a>
      ))}
    </div>

    <div class="overflow-x-auto rounded-lg border border-teal/20">
      <table class="w-full text-left text-sm">
        <thead class="bg-teal/30 text-xs uppercase text-white/80">
          <tr>
            <th class="px-4 py-3 font-medium">Applicant</th>
            <th class="px-4 py-3 font-medium">Program</th>
            <th class="px-4 py-3 font-medium">Status</th>
            <th class="px-4 py-3 font-medium">Date</th>
            <th class="px-4 py-3 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-teal/10">
          {applications.length === 0 ? (
            <tr>
              <td colspan="5" class="px-4 py-8 text-center text-white/40">
                {statusFilter
                  ? `No ${statusFilter.toLowerCase()} applications found.`
                  : "No applications yet. Applications appear here when students submit them."}
              </td>
            </tr>
          ) : (
            applications.map((app) => (
              <tr class="text-white/80 hover:bg-teal/10">
                <td class="px-4 py-3">{app.user?.name ?? "Unknown"}</td>
                <td class="px-4 py-3">{app.program?.name ?? "—"}</td>
                <td class="px-4 py-3">
                  <Badge variant={app.status.toLowerCase() as any} />
                </td>
                <td class="px-4 py-3">
                  {app.createdAt
                    ? new Date(app.createdAt).toLocaleDateString()
                    : "—"}
                </td>
                <td class="px-4 py-3">
                  <a
                    href={`/admin/applications/${app.id}`}
                    class="text-primary hover:underline"
                  >
                    View
                  </a>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
