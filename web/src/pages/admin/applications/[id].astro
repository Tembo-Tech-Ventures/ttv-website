---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Card from "@/components/common/Card.astro";
import Badge from "@/components/common/Badge.astro";
import { drizzle } from "drizzle-orm/d1";
import * as schema from "@/lib/db/schema";
import { eq } from "drizzle-orm";
import { env } from "cloudflare:workers";

const db = drizzle(env.DB, { schema });
const { id } = Astro.params;

if (!id) return Astro.redirect("/admin/applications");

// Handle POST — update status
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const newStatus = formData.get("status") as string;

  const updateData: Record<string, any> = { status: newStatus };
  if (newStatus === "COMPLETED") {
    updateData.completedAt = new Date();
  }

  await db
    .update(schema.programApplication)
    .set(updateData)
    .where(eq(schema.programApplication.id, id));

  return Astro.redirect(`/admin/applications/${id}`);
}

const application = await db.query.programApplication.findFirst({
  where: eq(schema.programApplication.id, id),
  with: { user: true, program: true },
});

if (!application) return Astro.redirect("/admin/applications");

// Parse application JSON
let appData: Record<string, any> = {};
try {
  appData = JSON.parse(application.application);
} catch {
  appData = { raw: application.application };
}

// Determine available status transitions
const transitions: Record<string, string[]> = {
  PENDING: ["APPROVED", "REJECTED", "AUDIT"],
  APPROVED: ["COMPLETED", "REJECTED"],
  REJECTED: [],
  AUDIT: ["APPROVED", "REJECTED"],
  COMPLETED: [],
};

const availableStatuses = transitions[application.status] ?? [];
---

<AdminLayout title="Application Detail">
  <div class="space-y-6">
    <a href="/admin/applications" class="text-sm text-primary hover:underline">
      &larr; Back to Applications
    </a>

    <div class="flex items-center gap-3">
      <h2 class="text-2xl font-bold text-white">Application</h2>
      <Badge variant={application.status.toLowerCase() as any} />
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <Card>
        <h3 class="mb-4 text-lg font-semibold text-white">Applicant</h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-white/60">Name</dt>
            <dd class="text-white">{application.user?.name ?? "Unknown"}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-white/60">Email</dt>
            <dd class="text-white">{application.user?.email ?? "—"}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-white/60">User</dt>
            <dd>
              <a
                href={`/admin/users/${application.userId}`}
                class="text-primary hover:underline"
              >
                View Profile
              </a>
            </dd>
          </div>
        </dl>
      </Card>

      <Card>
        <h3 class="mb-4 text-lg font-semibold text-white">Program</h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-white/60">Program</dt>
            <dd class="text-white">{application.program?.name ?? "—"}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-white/60">Applied</dt>
            <dd class="text-white">
              {application.createdAt
                ? new Date(application.createdAt).toLocaleDateString()
                : "—"}
            </dd>
          </div>
          {application.completedAt && (
            <div class="flex justify-between">
              <dt class="text-white/60">Completed</dt>
              <dd class="text-white">
                {new Date(application.completedAt).toLocaleDateString()}
              </dd>
            </div>
          )}
        </dl>
      </Card>
    </div>

    <Card>
      <h3 class="mb-4 text-lg font-semibold text-white">Application Data</h3>
      <dl class="space-y-3 text-sm">
        {Object.entries(appData).map(([key, value]) => (
          <div>
            <dt class="font-medium capitalize text-white/60">
              {key.replace(/([A-Z])/g, " $1").replace(/_/g, " ")}
            </dt>
            <dd class="mt-0.5 text-white">
              {typeof value === "object" ? JSON.stringify(value, null, 2) : String(value)}
            </dd>
          </div>
        ))}
      </dl>
    </Card>

    {availableStatuses.length > 0 && (
      <Card>
        <h3 class="mb-4 text-lg font-semibold text-white">Change Status</h3>
        <div class="flex flex-wrap gap-2">
          {availableStatuses.map((status) => (
            <form method="POST">
              <input type="hidden" name="status" value={status} />
              <button
                type="submit"
                class:list={[
                  "rounded-md px-4 py-2 text-sm font-medium transition-colors",
                  status === "APPROVED" && "bg-green-600 text-white hover:bg-green-700",
                  status === "REJECTED" && "bg-red-600 text-white hover:bg-red-700",
                  status === "AUDIT" && "bg-blue-600 text-white hover:bg-blue-700",
                  status === "COMPLETED" && "bg-purple-600 text-white hover:bg-purple-700",
                ]}
              >
                {status === "COMPLETED" ? "Mark Completed" : status.charAt(0) + status.slice(1).toLowerCase()}
              </button>
            </form>
          ))}
        </div>
      </Card>
    )}
  </div>
</AdminLayout>
