---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Card from "@/components/common/Card.astro";
import ProcessingStatus from "@/components/recordings/ProcessingStatus.astro";
import { getAccessibleProgramIds } from "@/lib/recordings/access";
import { formatDuration } from "@/lib/recordings/time-utils";
import { drizzle } from "drizzle-orm/d1";
import { and, inArray } from "drizzle-orm";
import * as schema from "@/lib/db/schema";
import { env } from "cloudflare:workers";

const user = Astro.locals.user!;
const db = drizzle(env.DB, { schema });
const programIds = await getAccessibleProgramIds(db, user.id);
const recordings =
  programIds.length > 0
    ? await db.query.recording.findMany({
        where: and(inArray(schema.recording.programId, programIds)),
        with: { program: true },
        orderBy: (recording, { desc }) => [desc(recording.recordedAt)],
      })
    : [];
---

<DashboardLayout title="Sessions">
  <div class="space-y-6">
    <div>
      <h2 class="text-2xl font-bold text-white">Sessions</h2>
      <p class="mt-1 text-sm text-white/55">
        Watch recorded sessions and follow along with the transcript.
      </p>
    </div>

    {recordings.length === 0 ? (
      <Card>
        <div class="py-10 text-center text-white/55">
          No session recordings are available for your programs yet.
        </div>
      </Card>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {recordings.map((recording) => (
          <a href={`/dashboard/sessions/${recording.id}`} class="block">
            <Card>
              <div class="space-y-4">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-base font-semibold text-white">{recording.title}</h3>
                  <ProcessingStatus status={recording.processingStatus} />
                </div>
                <p class="text-sm text-white/55">{recording.program?.name ?? "Program session"}</p>
                <div class="flex items-center justify-between text-xs text-white/45">
                  <span>{recording.recordedAt ? recording.recordedAt.toISOString().split("T")[0] : "No date"}</span>
                  <span>{formatDuration(recording.durationSeconds)}</span>
                </div>
              </div>
            </Card>
          </a>
        ))}
      </div>
    )}
  </div>
</DashboardLayout>
