---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Card from "@/components/common/Card.astro";
import { drizzle } from "drizzle-orm/d1";
import * as schema from "@/lib/db/schema";
import { eq } from "drizzle-orm";
import { env } from "cloudflare:workers";

const user = Astro.locals.user!;
const db = drizzle(env.DB, { schema });

let success = "";
let error = "";

// Handle POST — update user profile
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const name = (formData.get("name") as string)?.trim();

    if (!name) {
      error = "Name is required.";
    } else {
      await db
        .update(schema.user)
        .set({ name })
        .where(eq(schema.user.id, user.id));

      user.name = name;
      success = "Profile updated successfully!";
    }
  } catch (e) {
    error = "Something went wrong. Please try again.";
  }
}
---

<DashboardLayout title="Profile">
  <div class="space-y-6">
    <div>
      <h2 class="text-2xl font-bold text-white">Your Profile</h2>
      <p class="mt-1 text-white/60">
        Manage your account information.
      </p>
    </div>

    {success && (
      <div class="rounded-md border border-green-500/30 bg-green-500/10 p-4 text-green-300">
        {success}
      </div>
    )}

    {error && (
      <div class="rounded-md border border-red-500/30 bg-red-500/10 p-4 text-red-300">
        {error}
      </div>
    )}

    <div class="grid gap-6 lg:grid-cols-3">
      {/* Avatar section */}
      <Card>
        <div class="flex flex-col items-center gap-4 text-center">
          {user.image ? (
            <img
              src={user.image}
              alt={user.name}
              class="h-24 w-24 rounded-full border-2 border-primary"
            />
          ) : (
            <div class="flex h-24 w-24 items-center justify-center rounded-full bg-teal text-3xl font-bold text-white">
              {user.name.charAt(0).toUpperCase()}
            </div>
          )}
          <div>
            <p class="text-lg font-semibold text-white">{user.name}</p>
            <p class="text-sm text-white/60">{user.email}</p>
          </div>
        </div>
      </Card>

      {/* Edit form */}
      <Card class="lg:col-span-2">
        <h3 class="mb-4 text-lg font-semibold text-white">Edit Profile</h3>
        <form method="POST" class="space-y-4">
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-sm font-medium text-white/90">
              Name <span class="text-primary">*</span>
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              value={user.name}
              class="rounded-md border border-teal bg-dark/50 px-3 py-2 text-white placeholder:text-white/40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium text-white/90">
              Email
            </label>
            <input
              id="email"
              type="email"
              value={user.email}
              disabled
              class="rounded-md border border-teal bg-dark/50 px-3 py-2 text-white/50 cursor-not-allowed"
            />
            <p class="text-xs text-white/40">
              Email is managed by your GitHub account and cannot be changed here.
            </p>
          </div>

          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-2 font-medium text-dark hover:bg-primary/90 transition-colors"
          >
            Save Changes
          </button>
        </form>
      </Card>
    </div>
  </div>
</DashboardLayout>
