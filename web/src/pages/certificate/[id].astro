---
import CertificateLayout from "@/layouts/CertificateLayout.astro";
import { drizzle } from "drizzle-orm/d1";
import * as schema from "@/lib/db/schema";
import { eq } from "drizzle-orm";
import { format } from "date-fns";
import { env } from "cloudflare:workers";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/");
}

const db = drizzle(env.DB, { schema });

const application = await db.query.programApplication.findFirst({
  where: eq(schema.programApplication.id, id),
  with: {
    user: true,
    program: {
      with: {
        curriculum: true,
        programRoles: {
          with: { user: true },
        },
      },
    },
  },
});

const isValid = application?.status === "COMPLETED" && application.program;

const studentName = application?.user?.name ?? "Unknown";
const curriculumTitle = application?.program?.curriculum?.title ?? "";
const programName = application?.program?.name ?? "";
const instructor = application?.program?.programRoles?.find(
  (r) => r.name === "INSTRUCTOR"
);
const instructorName = instructor?.user?.name ?? "";
const issueDate = application?.completedAt
  ? format(application.completedAt, "MMMM dd, yyyy")
  : "";
---

<CertificateLayout title={isValid ? `Certificate - ${studentName}` : "Certificate Not Found"}>
  {!isValid ? (
    <div class="flex min-h-[60vh] flex-col items-center justify-center text-center">
      <h1 class="mb-4 text-2xl font-heading text-gray-800">Certificate Not Available</h1>
      <p class="text-gray-500">
        This certificate does not exist or has not yet been issued.
      </p>
    </div>
  ) : (
    <div class="certificate-wrapper">
      <div class="certificate">
        <!-- Decorative corner accents -->
        <div class="corner corner-tl"></div>
        <div class="corner corner-tr"></div>
        <div class="corner corner-bl"></div>
        <div class="corner corner-br"></div>

        <div class="certificate-inner">
          <!-- Header -->
          <div class="mb-2 text-center">
            <div class="mb-6 text-sm font-semibold uppercase tracking-[0.3em] text-teal">
              Tembo Tech Ventures
            </div>
            <h1 class="certificate-title font-heading text-primary">
              Certificate of Completion
            </h1>
            <div class="mx-auto mt-4 h-[2px] w-24 bg-primary opacity-60"></div>
          </div>

          <!-- Body -->
          <div class="mt-10 text-center">
            <p class="text-sm uppercase tracking-[0.2em] text-gray-400">
              This certifies that
            </p>

            <p class="student-name mt-4 font-body text-gray-900">
              {studentName}
            </p>

            <div class="mx-auto mt-2 h-px w-64 bg-gray-200"></div>

            <p class="mt-6 text-sm uppercase tracking-[0.2em] text-gray-400">
              has successfully completed
            </p>

            <p class="curriculum-title mt-4 font-heading text-teal">
              {curriculumTitle}
            </p>

            <p class="mt-2 text-lg text-gray-600">
              {programName}
            </p>
          </div>

          <!-- Footer details -->
          <div class="mt-12 grid grid-cols-2 gap-8 border-t border-gray-100 pt-8">
            <div class="text-left">
              {instructorName && (
                <div class="mb-4">
                  <div class="text-xs uppercase tracking-[0.15em] text-gray-400">Instructor</div>
                  <div class="mt-1 text-sm font-medium text-gray-700">{instructorName}</div>
                </div>
              )}
              <div>
                <div class="text-xs uppercase tracking-[0.15em] text-gray-400">Issue Date</div>
                <div class="mt-1 text-sm font-medium text-gray-700">{issueDate}</div>
              </div>
            </div>
            <div class="text-right">
              <div class="mb-4">
                <div class="text-xs uppercase tracking-[0.15em] text-gray-400">Certificate ID</div>
                <div class="mt-1 font-mono text-xs text-gray-500">{id}</div>
              </div>
            </div>
          </div>

          <!-- Branding footer -->
          <div class="mt-10 text-center">
            <div class="mx-auto h-px w-16 bg-primary opacity-40"></div>
            <p class="mt-4 text-xs uppercase tracking-[0.25em] text-gray-300">
              Tembo Tech Ventures
            </p>
          </div>
        </div>
      </div>
    </div>
  )}
</CertificateLayout>

<style>
  .certificate-wrapper {
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }

  .certificate {
    position: relative;
    width: 100%;
    max-width: 720px;
    padding: 3rem;
    border: 2px solid #2C6964;
    background: #fffdf9;
  }

  .certificate-inner {
    border: 1px solid rgba(242, 141, 104, 0.3);
    padding: 3rem 2.5rem;
  }

  /* Decorative corners */
  .corner {
    position: absolute;
    width: 24px;
    height: 24px;
  }

  .corner::before,
  .corner::after {
    content: "";
    position: absolute;
    background: #F28D68;
  }

  .corner::before {
    width: 24px;
    height: 3px;
  }

  .corner::after {
    width: 3px;
    height: 24px;
  }

  .corner-tl { top: 12px; left: 12px; }
  .corner-tl::before { top: 0; left: 0; }
  .corner-tl::after { top: 0; left: 0; }

  .corner-tr { top: 12px; right: 12px; }
  .corner-tr::before { top: 0; right: 0; }
  .corner-tr::after { top: 0; right: 0; }

  .corner-bl { bottom: 12px; left: 12px; }
  .corner-bl::before { bottom: 0; left: 0; }
  .corner-bl::after { bottom: 0; left: 0; }

  .corner-br { bottom: 12px; right: 12px; }
  .corner-br::before { bottom: 0; right: 0; }
  .corner-br::after { bottom: 0; right: 0; }

  .certificate-title {
    font-size: 2rem;
    line-height: 1.2;
  }

  .student-name {
    font-size: 2rem;
    font-weight: 700;
  }

  .curriculum-title {
    font-size: 1.35rem;
    line-height: 1.3;
  }

  /* Print styles */
  @media print {
    .certificate-wrapper {
      padding: 0;
    }

    .certificate {
      border-color: #2C6964;
      box-shadow: none;
      max-width: none;
    }
  }
</style>
