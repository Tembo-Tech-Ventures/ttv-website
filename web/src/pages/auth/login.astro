---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Grain from "@/components/common/Grain.astro";
import Elephant from "@/components/brand/Elephant.astro";
import GitHubSignInButton from "@/components/auth/GitHubSignInButton";

/**
 * Auth / Login — split-screen editorial (PROPOSAL §6).
 *
 * The old screen was 80% empty on dark mode, which read as broken. This
 * version splits 50/50: brand voice + sign-in on the left, a pull quote
 * and line-art elephant on the right so the page is never hollow. Copy
 * moves from system voice ("Sign in to access your dashboard") to brand
 * voice ("Pick up where you left off.").
 */

if (Astro.locals.user) {
  return Astro.redirect("/dashboard");
}
---

<BaseLayout title="Sign In · Tembo Tech Ventures">
  <Grain />

  <main
    class="relative z-[2] grid min-h-screen grid-cols-1 md:grid-cols-2"
    style="background: radial-gradient(900px 500px at 20% 0%, rgba(242,141,104,0.10), transparent 60%), linear-gradient(180deg, #013D39 0%, #012A28 100%);"
  >
    <!-- Left: sign-in -->
    <section class="relative flex items-center justify-center px-6 py-16 md:px-16">
      <div class="w-full max-w-md">
        <a href="/" class="inline-flex items-center gap-2 text-ink-primary">
          <Elephant size={30} strokeWidth={1.8} class="text-primary" />
          <span class="font-body text-xs font-bold uppercase tracking-[0.28em]">TTV</span>
        </a>

        <p class="font-body mt-12 text-xs font-semibold uppercase tracking-[0.4em] text-primary">
          § Welcome back
        </p>

        <h1
          class="font-heading mt-4 text-ink-primary"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 0.95; letter-spacing: -0.03em;"
        >
          Pick up where
          <br />
          you left off.
        </h1>

        <p class="font-body mt-6 text-lg text-ink-secondary">
          Sign in and get back to building. Your cohort, applications, and
          mentor notes are all waiting.
        </p>

        <div class="mt-10 space-y-4">
          <GitHubSignInButton client:load />
          <p class="font-body text-center text-xs text-ink-muted">
            By signing in, you agree to our terms of service.
          </p>
        </div>
      </div>
    </section>

    <!-- Right: pull quote + elephant -->
    <aside
      class="relative hidden items-center justify-center overflow-hidden border-l border-[color:var(--color-rule)] px-10 py-16 md:flex"
      style="background-color: var(--color-bg-raised);"
    >
      <div class="relative max-w-lg space-y-10">
        <p class="font-body text-xs font-semibold uppercase tracking-[0.4em] text-primary">
          From the cohort
        </p>
        <blockquote
          class="font-heading text-ink-primary"
          style="font-size: clamp(2rem, 3.2vw, 3.25rem); line-height: 1.05; letter-spacing: -0.02em;"
        >
          &ldquo;I came in thinking I&apos;d be taught. I left knowing I was
          <span class="text-primary">trusted to deliver</span>.&rdquo;
        </blockquote>
        <footer class="font-body text-sm uppercase tracking-[0.24em] text-ink-muted">
          Asha Njeri · Cohort 03 · Backend engineer
        </footer>

        <div aria-hidden="true" class="absolute -right-20 -bottom-24 text-primary/30">
          <Elephant size={340} strokeWidth={1.2} breathing />
        </div>
      </div>
    </aside>
  </main>
</BaseLayout>
